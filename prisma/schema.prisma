// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==========================================
// Auth.js v5 Models
// ==========================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?

  // Stripe
  stripeCustomerId       String?   @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?

  // Plan
  plan         Plan         @default(FREE)
  billingCycle BillingCycle @default(MONTHLY)

  // Relations
  accounts  Account[]
  sessions  Session[]
  companies Company[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

// ==========================================
// Business Models — +NOTA
// ==========================================

model Company {
  id              String    @id @default(cuid())
  cnpj            String    @unique
  razaoSocial     String
  nomeFantasia    String?
  ie              String?   // Inscrição Estadual
  im              String?   // Inscrição Municipal
  crt             TaxRegime @default(SIMPLES_NACIONAL)
  endereco        Json?     // {logradouro, numero, complemento, bairro, cidade, uf, cep, codigoMunicipio}
  uf              String?

  // Certificado Digital A1
  certificateFile     Bytes?
  certificatePassword String?
  certificateExpiry   DateTime?

  isActive Boolean @default(true)

  // Relations
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  customers Customer[]
  products  Product[]
  invoices  Invoice[]
  taxConfigs TaxConfig[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Customer {
  id        String  @id @default(cuid())
  cpfCnpj   String
  name      String
  email     String?
  phone     String?
  address   Json?   // {logradouro, numero, complemento, bairro, cidade, uf, cep, codigoMunicipio}
  ie        String? // Inscrição Estadual (se PJ)
  isCompany Boolean @default(false)

  // Relations
  companyId String
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices  Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([cpfCnpj])
}

model Product {
  id          String      @id @default(cuid())
  code        String      // Código interno
  name        String
  description String?
  ncm         String?     // Nomenclatura Comum do Mercosul
  cfop        String?     // Código Fiscal de Operações
  cst         String?     // Código de Situação Tributária
  unit        String      @default("UN") // Unidade de medida
  price       Float       @default(0)
  gtin        String?     // Código de barras (GTIN/EAN)
  type        ProductType @default(PRODUCT)

  // Relations
  companyId    String
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoiceItems InvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([code])
}

model Invoice {
  id     String       @id @default(cuid())
  model  InvoiceModel
  series Int          @default(1)
  number Int          @default(0)
  status InvoiceStatus @default(DRAFT)

  // XML & Protocol
  xmlContent        String?   @db.Text
  xmlSigned         String?   @db.Text
  protocol          String?
  accessKey         String?   @unique
  authorizationDate DateTime?
  cancelDate        DateTime?
  danfeUrl          String?

  // Values
  totalValue     Float @default(0)
  totalIcms      Float @default(0)
  totalPis       Float @default(0)
  totalCofins    Float @default(0)
  totalDiscount  Float @default(0)

  // Payment
  paymentMethod String? // 01=Dinheiro, 02=Cheque, 03=Cartão Crédito, etc.

  // Contingency
  contingencyType String?

  // Additional info
  natOp       String? // Natureza da operação (ex: "Venda de mercadoria")
  infoComplementar String? @db.Text

  // Relations
  companyId  String
  company    Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  items  InvoiceItem[]
  events InvoiceEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model InvoiceItem {
  id        String @id @default(cuid())
  sequence  Int    @default(1) // nItem no XML

  quantity  Float
  unitPrice Float
  totalPrice Float

  // Tax info per item
  cfop         String?
  ncm          String?
  cst          String?

  // ICMS
  icmsBase     Float @default(0)
  icmsRate     Float @default(0)
  icmsValue    Float @default(0)

  // PIS
  pisBase      Float @default(0)
  pisRate      Float @default(0)
  pisValue     Float @default(0)

  // COFINS
  cofinsBase   Float @default(0)
  cofinsRate   Float @default(0)
  cofinsValue  Float @default(0)

  // Relations
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
}

model InvoiceEvent {
  id       String    @id @default(cuid())
  type     EventType
  protocol String?
  xmlEvent String?   @db.Text
  reason   String?

  // Relations
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([invoiceId])
}

model TaxConfig {
  id          String @id @default(cuid())
  uf          String // Estado (ex: "SP", "RJ")
  cfop        String
  cstIcms     String?
  cstPis      String?
  cstCofins   String?
  icmsRate    Float  @default(0)
  pisRate     Float  @default(0)
  cofinsRate  Float  @default(0)
  description String?

  // Relations
  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([companyId])
  @@index([uf])
}

// ==========================================
// Enums
// ==========================================

enum Plan {
  FREE
  PRO
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum TaxRegime {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
}

enum ProductType {
  PRODUCT
  SERVICE
}

enum InvoiceModel {
  NFE_55
  NFCE_65
  NFSE
}

enum InvoiceStatus {
  DRAFT
  PENDING
  AUTHORIZED
  REJECTED
  CANCELLED
  CONTINGENCY
}

enum EventType {
  CANCEL
  CORRECTION
  MANIFESTATION
  INUTILIZATION
}
