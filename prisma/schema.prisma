generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String       @id @default(cuid())
  name                   String?
  email                  String       @unique
  emailVerified          DateTime?
  image                  String?
  password               String?
  stripeCustomerId       String?      @unique
  stripePriceId          String?
  stripeCurrentPeriodEnd DateTime?
  plan                   Plan         @default(FREE)
  billingCycle           BillingCycle @default(MONTHLY)
  createdAt              DateTime     @default(now())
  updatedAt              DateTime     @updatedAt
  accounts               Account[]
  companies              Company[]
  sessions               Session[]
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
}

model Company {
  id                  String      @id @default(cuid())
  cnpj                String      @unique
  razaoSocial         String
  nomeFantasia        String?
  ie                  String?
  im                  String?
  crt                 TaxRegime   @default(SIMPLES_NACIONAL)
  endereco            Json?
  uf                  String?
  certificateFile     Bytes?
  certificatePassword String?
  certificateExpiry   DateTime?
  isActive            Boolean     @default(true)
  userId              String
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  customers           Customer[]
  invoices            Invoice[]
  products            Product[]
  taxConfigs          TaxConfig[]

  @@index([userId])
}

model Customer {
  id        String    @id @default(cuid())
  cpfCnpj   String
  name      String
  email     String?
  phone     String?
  address   Json?
  ie        String?
  isCompany Boolean   @default(false)
  companyId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  company   Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices  Invoice[]

  @@index([companyId])
  @@index([cpfCnpj])
}

model Product {
  id           String        @id @default(cuid())
  code         String
  name         String
  description  String?
  ncm          String?
  cfop         String?
  cst          String?
  unit         String        @default("UN")
  price        Float         @default(0)
  gtin         String?
  type         ProductType   @default(PRODUCT)
  companyId    String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  invoiceItems InvoiceItem[]
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([code])
}

model Invoice {
  id                String         @id @default(cuid())
  model             InvoiceModel
  series            Int            @default(1)
  number            Int            @default(0)
  status            InvoiceStatus  @default(DRAFT)
  xmlContent        String?
  xmlSigned         String?
  protocol          String?
  accessKey         String?        @unique
  authorizationDate DateTime?
  cancelDate        DateTime?
  danfeUrl          String?
  totalValue        Float          @default(0)
  totalIcms         Float          @default(0)
  totalPis          Float          @default(0)
  totalCofins       Float          @default(0)
  totalDiscount     Float          @default(0)
  paymentMethod     String?
  contingencyType   String?
  natOp             String?
  infoComplementar  String?
  companyId         String
  customerId        String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  company           Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  customer          Customer?      @relation(fields: [customerId], references: [id])
  events            InvoiceEvent[]
  items             InvoiceItem[]

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model InvoiceItem {
  id          String   @id @default(cuid())
  sequence    Int      @default(1)
  quantity    Float
  unitPrice   Float
  totalPrice  Float
  cfop        String?
  ncm         String?
  cst         String?
  icmsBase    Float    @default(0)
  icmsRate    Float    @default(0)
  icmsValue   Float    @default(0)
  pisBase     Float    @default(0)
  pisRate     Float    @default(0)
  pisValue    Float    @default(0)
  cofinsBase  Float    @default(0)
  cofinsRate  Float    @default(0)
  cofinsValue Float    @default(0)
  invoiceId   String
  productId   String?
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id])

  @@index([invoiceId])
}

model InvoiceEvent {
  id        String    @id @default(cuid())
  type      EventType
  protocol  String?
  xmlEvent  String?
  reason    String?
  invoiceId String
  createdAt DateTime  @default(now())
  invoice   Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model TaxConfig {
  id          String   @id @default(cuid())
  uf          String
  cfop        String
  cstIcms     String?
  cstPis      String?
  cstCofins   String?
  icmsRate    Float    @default(0)
  pisRate     Float    @default(0)
  cofinsRate  Float    @default(0)
  description String?
  companyId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([uf])
}

enum Plan {
  FREE
  PRO
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

enum TaxRegime {
  SIMPLES_NACIONAL
  LUCRO_PRESUMIDO
  LUCRO_REAL
}

enum ProductType {
  PRODUCT
  SERVICE
}

enum InvoiceModel {
  NFE_55
  NFCE_65
  NFSE
}

enum InvoiceStatus {
  DRAFT
  PENDING
  AUTHORIZED
  REJECTED
  CANCELLED
  CONTINGENCY
}

enum EventType {
  CANCEL
  CORRECTION
  MANIFESTATION
  INUTILIZATION
}
